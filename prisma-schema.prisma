// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  username      String     @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  avatar        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  chatMessages  ChatMessage[]
  explanations  Explanation[]
  savedItems    SavedItem[]

  @@map("users")
}

model Country {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique
  
  subjects  Subject[]
  textbooks Textbook[]

  @@map("countries")
}

model Grade {
  id        String     @id @default(cuid())
  level     Int        @unique
  name      String

  subjects  Subject[]
  textbooks Textbook[]

  @@map("grades")
}

model Subject {
  id        String     @id @default(cuid())
  name      String
  code      String
  
  gradeId   String
  grade     Grade      @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  
  countryId String
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  topics    Topic[]
  textbooks Textbook[]

  @@unique([name, gradeId, countryId])
  @@map("subjects")
}

model Topic {
  id          String     @id @default(cuid())
  title       String
  description String?
  order       Int        @default(0)
  
  subjectId   String
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  explanations Explanation[]

  @@map("topics")
}

model Textbook {
  id          String     @id @default(cuid())
  title       String
  author      String?
  publisher   String?
  year        Int?
  isbn        String?
  description String?
  coverImage  String?
  
  countryId   String
  country     Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  
  gradeId     String
  grade       Grade      @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  
  subjectId   String
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  chapters    Chapter[]
  savedItems  SavedItem[]

  @@unique([isbn])
  @@map("textbooks")
}

model Chapter {
  id          String     @id @default(cuid())
  title       String
  number      Int
  content     String?
  
  textbookId  String
  textbook    Textbook   @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@map("chapters")
}

model ChatMessage {
  id          String     @id @default(cuid())
  role        String     // "user" or "assistant"
  content     String
  imageUrl    String?
  createdAt   DateTime   @default(now())
  
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  explanationId String?
  explanation Explanation?  @relation(fields: [explanationId], references: [id])

  @@map("chat_messages")
}

model Explanation {
  id            String     @id @default(cuid())
  topicId       String?
  topic         Topic?     @relation(fields: [topicId], references: [id])
  question      String
  answer        String
  tokens_used   Int?
  createdAt     DateTime   @default(now())
  
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  chatMessages  ChatMessage[]

  @@map("explanations")
}

model SavedItem {
  id          String     @id @default(cuid())
  type        String     // "textbook", "topic", "explanation"
  itemId      String
  createdAt   DateTime   @default(now())
  
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  textbookId  String?
  textbook    Textbook?  @relation(fields: [textbookId], references: [id], onDelete: Cascade)

  @@map("saved_items")
}
